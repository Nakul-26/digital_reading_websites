# Runtime
NODE_ENV=development
PORT=3000

# Database
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
MONGO_DB_NAME=novel_website

# Auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1h
JWT_COOKIE_MAX_AGE_MS=604800000
BCRYPT_ROUNDS=12

# Security / CORS
CORS_ORIGIN=http://localhost:5173
API_RATE_LIMIT_MAX=1000
AUTH_RATE_LIMIT_MAX=10
UPLOAD_RATE_LIMIT_MAX=10
LOGIN_MAX_FAILED_ATTEMPTS=15
LOGIN_LOCKOUT_MINUTES=15

# Cloudinary
CLOUDINARY_CLOUD_NAME=dnlpirpsq
CLOUDINARY_API_KEY=541534669375251
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret
